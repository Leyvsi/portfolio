{
  "swagger": "2.0",
  "info": {
    "title": "Les Petits Enquêteurs API",
    "version": "1.0.0",
    "description": "Interface de test complète et catégorisée incluant le système de signalement et de modération."
  },
  "basePath": "/api/v1",
  "tags": [
    { "name": "Configuration & Stats", "description": "Données globales du site" },
    { "name": "Gestion des Utilisateurs", "description": "Inscription, liste et signalements" },
    { "name": "Histoires & Votes", "description": "Consultation et système de vote" },
    { "name": "Cold Cases & Théories", "description": "Gestion des enquêtes non résolues et des espaces d'échange" },
    { "name": "Modération Admin", "description": "Espace privé pour trier et supprimer les contenus signalés" }
  ],
  "paths": {
    "/stats": {
      "get": {
        "tags": ["Configuration & Stats"],
        "summary": "Récupérer le nombre de visites",
        "responses": { "200": { "description": "Succès" } }
      }
    },
    "/users": {
      "get": {
        "tags": ["Gestion des Utilisateurs"],
        "summary": "Récupérer la liste des utilisateurs actifs",
        "responses": { "200": { "description": "Succès" } }
      },
      "post": {
        "tags": ["Gestion des Utilisateurs"],
        "summary": "Inscrire un nouvel utilisateur",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "username": { "type": "string", "example": "DetectiveSylvie" },
                "email": { "type": "string", "example": "sylvie@example.com" },
                "password": { "type": "string", "example": "CyberSec2026!" }
              }
            }
          }
        ],
        "responses": { "201": { "description": "Succès" } }
      }
    },
    "/reports": {
      "post": {
        "tags": ["Gestion des Utilisateurs"],
        "summary": "Signaler un contenu problématique (commentaire, photo, utilisateur)",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "example": "commentaire" },
                "target_id": { "type": "string", "example": "t_a1b2c3d4" },
                "reason": { "type": "string", "example": "Propos injurieux ou inappropriés" }
              }
            }
          }
        ],
        "responses": { "201": { "description": "Signalement enregistré" } }
      }
    },
    "/stories": {
      "get": {
        "tags": ["Histoires & Votes"],
        "summary": "Liste des histoires",
        "responses": { "200": { "description": "Succès" } }
      }
    },
    "/votes/{story_id}": {
      "post": {
        "tags": ["Histoires & Votes"],
        "summary": "Voter pour une histoire",
        "parameters": [{ "name": "story_id", "in": "path", "required": true, "type": "string" }],
        "responses": { "200": { "description": "Vote pris en compte" } }
      }
    },
    "/coldcases/{case_id}/theories": {
      "get": {
        "tags": ["Cold Cases & Théories"],
        "summary": "Récupérer les théories d'un cold case",
        "parameters": [{ "name": "case_id", "in": "path", "required": true, "type": "string" }],
        "responses": { "200": { "description": "Succès" } }
      },
      "post": {
        "tags": ["Cold Cases & Théories"],
        "summary": "Ajouter une théorie",
        "parameters": [
          { "name": "case_id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "author": { "type": "string" },
                "text": { "type": "string" }
              }
            }
          }
        ],
        "responses": { "201": { "description": "Succès" } }
      }
    },
    "/admin/reports": {
      "get": {
        "tags": ["Modération Admin"],
        "summary": "Voir la liste de tous les signalements effectués",
        "responses": { "200": { "description": "Succès" } }
      }
    },
    "/admin/users/{username}/ban": {
      "delete": {
        "tags": ["Modération Admin"],
        "summary": "Bannir et supprimer définitivement un utilisateur",
        "parameters": [{ "name": "username", "in": "path", "required": true, "type": "string" }],
        "responses": { "200": { "description": "Utilisateur banni" } }
      }
    }
  }
}
